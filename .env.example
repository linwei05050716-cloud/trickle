# Trickle configuration

# Settlement backend: "mock" (local, zero-deps) or "arc" (real Circle Gateway)
TRICKLE_SETTLEMENT=mock

# Port for the local server
PORT=4021

# Ambient simulated audience (real sessions joining/leaving) for lively demos.
# "on" (default) or "off".
TRICKLE_AUDIENCE=on

# --- Required only when TRICKLE_SETTLEMENT=arc ---
# Create a Circle developer account, then an API key:
#   https://developers.circle.com
CIRCLE_API_KEY=
# Gateway nanopayments endpoint (defaults to Circle's hosted Gateway API)
CIRCLE_GATEWAY_URL=https://api.circle.com/v1/w3s/gateway
